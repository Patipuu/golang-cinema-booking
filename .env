# Server
PORT=8080
ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=hallelujah1098
DB_NAME=booking_cinema
DB_SSLMODE=disable

# JWT (token valid 24h)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY_HOURS=24

# OTP (valid 10 minutes)
OTP_EXPIRY_MINUTES=10

# Email (for OTP - optional, e.g. SMTP)
# If SMTP_USER or SMTP_PASSWORD is empty, the backend will log OTP codes to console for local testing.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@booking-cinema.local
