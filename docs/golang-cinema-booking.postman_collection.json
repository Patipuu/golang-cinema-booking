        {
          "name": "01 register success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var res = pm.response.json();",
                  "pm.test('success true', function () {",
                  "    pm.expect(res.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('safe user payload', function () {",
                  "    pm.expect(res.data).to.have.property('id');",
                  "    pm.expect(res.data).to.have.property('email');",
                  "    pm.expect(res.data).to.have.property('username');",
                  "    pm.expect(res.data).to.have.property('phone');",
                  "    pm.expect(res.data).to.have.property('is_verified');",
                  "    pm.expect(res.data).to.not.have.property('password_hash');",
                  "    pm.expect(res.data).to.not.have.property('otp_code');",
                  "    pm.expect(res.data).to.not.have.property('otp_expiry');",
                  "});",
                  "",
                  "if (res.data && res.data.id) {",
                  "    pm.collectionVariables.set('user_id', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
